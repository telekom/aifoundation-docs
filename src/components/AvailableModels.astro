---
import 'flag-icons/css/flag-icons.min.css';
import pricingData from './PlansPageFeatures/PlansData/PlansModelData/v1.20.2/all-pricing--2026-04-24.json';

// Locale detection (mirrors PlansPage.astro pattern)
const isDE = Astro.url.pathname.startsWith('/de/') || Astro.url.pathname === '/de';

const t = {
  cloud: isDE ? 'Cloud' : 'Cloud',
  serverLocation: isDE ? 'Serverstandort' : 'Server Location',
  dataProcessing: isDE ? 'Datenverarbeitung' : 'Data Processing',
  showMoreTemplate: isDE ? '{count} weitere anzeigen' : 'Show More ({count} more)',
  showLess: isDE ? 'Weniger anzeigen' : 'Show Less',
  sectionHeading: isDE ? 'Verfügbare Modelle' : 'Available Models',
};

const OFFLINE_MODELS = new Set([
  'gpt-4.1-nano',
  'gpt-4o-mini',
  'GPT-5-Codex',
  'gpt-5-nano',
  'Mistral-Large-2411',
  'Mistral-Medium-3',
  'o1',
  'text-embedding-ada-002',
]);

const EXTRA_MODELS = [
  { modelId: 'gpt-5.2', name: 'GPT 5.2', provider: 'Azure', hosted: 'Sweden', countryCode: 'se', dataProcessing: 'EU' },
  {
    modelId: 'Qwen3-Coder-30B-A3B-Instruct-FP8',
    name: 'Qwen 3 Coder 30B',
    provider: 'T-Cloud',
    hosted: 'Germany',
    countryCode: 'de',
    dataProcessing: 'Germany',
  },
];

const SORT_ORDER = [
  'Gemma 4',
  'GPT-OSS 120B',
  'Qwen3-Next 80B',
  'Qwen3-VL 30B',
  'Qwen3 Coder 30B',
  'Qwen 3 Coder 30B',
  'Llama 3.3 70B',
  'Mistral Small 3',
  'Mistral Medium 3',
  'GPT-5.2',
  'GPT 5.2',
  'GPT-5',
  'GPT-5 mini',
  'GPT-5 nano',
  'GPT-5 Codex',
  'o4 mini',
  'o3',
  'o3 mini',
  'o1 mini',
  'Claude 4.6 Opus',
  'Claude 4.6 Sonnet',
  'Claude 4.5 Opus',
  'Claude 4.5 Sonnet (>200k)',
  'Claude 4.5 Sonnet (≤200k)',
  'Claude 4.5 Haiku',
  'Claude 4 Sonnet',
  'Claude 3.7 Sonnet',
  'Gemini 3 Pro (>200k)',
  'Gemini 3 Pro (≤200k)',
  'Gemini 3 Flash',
  'Gemini 2.5 Pro (>200k)',
  'Gemini 2.5 Pro (≤200k)',
  'Gemini 2.5 Flash',
  'Gemini 2.5 Flash Image',
  'GPT-4.1',
  'GPT-4.1 mini',
  'GPT-4.1 nano',
  'GPT-4o',
  'GPT-4o mini',
  'GPT-Image-1 (Text→Image)',
  'GPT-Image-1 (Image→Image)',
  'BGE-M3',
  'Ada Text Embedding',
  'Jina Embeddings v2 Base DE',
  'Whisper Large v3',
  'Whisper Large v3 Turbo',
];

// Map country names to ISO 3166-1 alpha-2 codes for flag icons
const COUNTRY_TO_CODE: Record<string, string> = {
  germany: 'de',
  sweden: 'se',
  france: 'fr',
  europe: 'eu',
  us: 'us',
};

function getCountryCode(countryName: string): string {
  return COUNTRY_TO_CODE[countryName.toLowerCase()] ?? '';
}

function parseRegion(region: string): { provider: string; hosted: string; countryCode: string } {
  const parts = region.split('-');
  const raw = parts[0].toLowerCase();
  const PROVIDER_MAP: Record<string, string> = { otc: 'T-Cloud', azure: 'Azure', gcp: 'GCP' };
  const provider = PROVIDER_MAP[raw] ?? raw.charAt(0).toUpperCase() + raw.slice(1);

  let country = parts[1] ?? '';
  country = country.charAt(0).toUpperCase() + country.slice(1).toLowerCase();
  const countryCode = getCountryCode(country);

  const dataProcessing = raw === 'otc' ? 'Germany' : 'EU';
  return { provider, hosted: country, countryCode, dataProcessing };
}

// Pull from the Agentic and Test plans so preview-only models (e.g. Gemma 4) are included.
// Tag Test-plan models so they can be marked as preview downstream.
const exposedPlans = [pricingData[pricingData.length - 2], pricingData[pricingData.length - 1]];
const configs = exposedPlans.flatMap((p) =>
  p.modelQuotaConfigs.map((c) => ({ ...c, isPreview: p.packageName === 'Test' })),
);

interface ModelCard {
  modelId: string;
  name: string;
  provider: string;
  hosted: string;
  countryCode: string;
  dataProcessing: string;
  preview?: boolean;
}

// Build model cards from pricing data (filtering out offline models)
const pricingModels: ModelCard[] = configs
  .filter((c: { exactModelName: string }) => !OFFLINE_MODELS.has(c.exactModelName))
  .map((c: { exactModelName: string; displayModelName: string; deploymentRegion: string; isPreview: boolean }) => {
    const { provider, hosted, countryCode, dataProcessing } = parseRegion(c.deploymentRegion);
    return {
      modelId: c.exactModelName,
      name: c.displayModelName,
      provider,
      hosted,
      countryCode,
      dataProcessing,
      preview: c.isPreview,
    };
  });

// Combine with extra models
const allModels: ModelCard[] = [...pricingModels, ...EXTRA_MODELS];

// Deduplicate by name (extras override pricing if same name)
const modelMap = new Map<string, ModelCard>();
for (const m of allModels) {
  modelMap.set(m.name, m);
}

// Sort: preview (newest) first, then by priority list, then alphabetical for unlisted
const sortedModels = [...modelMap.values()].sort((a, b) => {
  if (a.preview !== b.preview) return a.preview ? -1 : 1;
  const ai = SORT_ORDER.indexOf(a.name);
  const bi = SORT_ORDER.indexOf(b.name);
  if (ai !== -1 && bi !== -1) return ai - bi;
  if (ai !== -1) return -1;
  if (bi !== -1) return 1;
  return a.name.localeCompare(b.name);
});

const INITIAL_COUNT = 6;
---

<div class="available-models">
  <h2 class="models-heading">{t.sectionHeading} <span class="models-count">({sortedModels.length})</span></h2>
  <span id="copy-status" class="copy-status" aria-live="polite" aria-atomic="true"></span>
  <div class="models-grid" id="models-grid">
    {
      sortedModels.map((model, index) => (
        <div class:list={['model-card', { 'model-card--hidden': index >= INITIAL_COUNT }]} data-index={index}>
          <button
            class="model-card__copy"
            data-model-id={model.modelId}
            title={`Copy model ID: ${model.modelId}`}
            aria-label={`Copy model ID ${model.modelId}`}>
            <>
              <svg
                class="icon-copy"
                xmlns="http://www.w3.org/2000/svg"
                width="16"
                height="16"
                viewBox="0 0 24 24"
                fill="none"
                stroke="currentColor"
                stroke-width="2"
                stroke-linecap="round"
                stroke-linejoin="round"
                aria-hidden="true">
                <>
                  <rect x="9" y="9" width="13" height="13" rx="2" ry="2" />
                  <path d="M5 15H4a2 2 0 0 1-2-2V4a2 2 0 0 1 2-2h9a2 2 0 0 1 2 2v1" />
                </>
              </svg>
              <svg
                class="icon-check"
                xmlns="http://www.w3.org/2000/svg"
                width="16"
                height="16"
                viewBox="0 0 24 24"
                fill="none"
                stroke="currentColor"
                stroke-width="2"
                stroke-linecap="round"
                stroke-linejoin="round"
                aria-hidden="true">
                <polyline points="20 6 9 17 4 12" />
              </svg>
            </>
          </button>
          <h3 class="model-card__name">
            {model.name}
            {model.preview && <span class="model-card__preview-tag"> – Preview</span>}
          </h3>
          <div class="model-card__details">
            <span>
              {t.cloud}: <strong>{model.provider}</strong>
            </span>
            <span>
              {t.serverLocation}: <strong>{model.hosted}</strong>{' '}
              {model.countryCode && <span class={`fi fi-${model.countryCode}`} style="margin-left: 4px;" />}
            </span>
            <span>
              {t.dataProcessing}: <strong>{model.dataProcessing}</strong>
            </span>
          </div>
        </div>
      ))
    }
  </div>
  {
    sortedModels.length > INITIAL_COUNT && (
      <button
        class="models-toggle"
        id="models-toggle"
        data-total={sortedModels.length}
        data-initial={INITIAL_COUNT}
        data-show-more-template={t.showMoreTemplate}
        data-show-less={t.showLess}>
        {t.showMoreTemplate.replace('{count}', String(sortedModels.length - INITIAL_COUNT))}
      </button>
    )
  }
</div>

<style>
  .available-models {
    margin: 1.5rem 0;
  }

  .models-heading {
    margin-bottom: 1rem;
  }

  .models-count {
    font-size: 0.75em;
    font-weight: 400;
    color: var(--sl-color-gray-3);
    vertical-align: middle;
  }

  .models-grid > .model-card {
    margin: 0;
  }

  .models-grid {
    display: grid;
    gap: 1rem;
    grid-template-columns: 1fr;
    align-items: stretch;
  }

  @media (min-width: 640px) {
    .models-grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  @media (min-width: 960px) {
    .models-grid {
      grid-template-columns: repeat(3, 1fr);
    }
  }

  .model-card {
    position: relative;
    background: var(--sl-color-gray-6);
    color: var(--sl-color-white);
    border-radius: 0.5rem;
    padding: 1rem 2rem;
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
    text-align: center;
  }

  .model-card--hidden {
    display: none;
  }

  .model-card__name {
    margin: 0;
    font-size: 1rem;
    font-weight: 600;
    color: var(--sl-color-white);
    min-height: 2.5em;
  }

  .model-card__preview-tag {
    font-weight: 500;
    color: var(--sl-color-text-accent);
  }

  .model-card__copy {
    position: absolute;
    top: 0.5rem;
    right: 0.5rem;
    background: none;
    border: none;
    cursor: pointer;
    padding: 0.25rem;
    color: var(--sl-color-gray-3);
    opacity: 0.6;
    transition: opacity 0.15s;
  }

  .model-card__copy:hover {
    opacity: 1;
    color: var(--sl-color-white);
  }

  .model-card__copy .icon-check {
    display: none;
    color: #4ade80;
  }

  .model-card__copy[data-copied] .icon-copy {
    display: none;
  }

  .model-card__copy[data-copied] .icon-check {
    display: inline;
  }

  .model-card__copy[data-copied] {
    opacity: 1;
    color: #4ade80;
  }

  .copy-status {
    position: absolute;
    width: 1px;
    height: 1px;
    overflow: hidden;
    clip: rect(0 0 0 0);
    white-space: nowrap;
  }

  .model-card__details {
    display: flex;
    flex-direction: column;
    gap: 0.25rem;
    font-size: 0.85rem;
    color: var(--sl-color-gray-2, var(--sl-color-white));
  }

  .model-card__provider {
    font-weight: 500;
  }

  .models-toggle {
    display: block;
    margin: 1.25rem auto 0;
    padding: 0.5rem 1.5rem;
    font-size: 0.9rem;
    font-weight: 500;
    color: var(--sl-color-white);
    background: var(--sl-color-gray-5, var(--sl-color-gray-6));
    border: 1px solid var(--sl-color-gray-4, var(--sl-color-gray-5));
    border-radius: 0.375rem;
    cursor: pointer;
    transition: background 0.15s;
  }

  .models-toggle:hover {
    background: var(--sl-color-gray-4, var(--sl-color-gray-5));
  }
</style>

<script>
  function setup() {
    const toggle = document.getElementById('models-toggle') as HTMLButtonElement | null;
    if (!toggle) return;

    const total = Number(toggle.dataset.total);
    const initial = Number(toggle.dataset.initial);
    const showMoreTemplate = toggle.dataset.showMoreTemplate ?? 'Show More ({count} more)';
    const showLess = toggle.dataset.showLess ?? 'Show Less';
    let expanded = false;

    toggle.addEventListener('click', () => {
      expanded = !expanded;
      const cards = document.querySelectorAll<HTMLElement>('.model-card');
      cards.forEach((card) => {
        const idx = Number(card.dataset.index);
        if (idx >= initial) {
          card.classList.toggle('model-card--hidden', !expanded);
        }
      });
      toggle.textContent = expanded ? showLess : showMoreTemplate.replace('{count}', String(total - initial));
    });

    // Copy model ID to clipboard with visual + accessible feedback
    const copyStatus = document.getElementById('copy-status');
    document.querySelectorAll<HTMLButtonElement>('.model-card__copy').forEach((btn) => {
      btn.addEventListener('click', async () => {
        const modelId = btn.dataset.modelId;
        if (!modelId) return;
        try {
          await navigator.clipboard.writeText(modelId);
          // Visual feedback: swap icon for 1500ms
          btn.setAttribute('data-copied', '');
          const originalLabel = btn.getAttribute('aria-label') ?? '';
          btn.setAttribute('aria-label', `Copied ${modelId}`);
          if (copyStatus) copyStatus.textContent = `Copied ${modelId}`;
          setTimeout(() => {
            btn.removeAttribute('data-copied');
            btn.setAttribute('aria-label', originalLabel);
            if (copyStatus) copyStatus.textContent = '';
          }, 1500);
        } catch {
          // Fallback: do nothing silently
        }
      });
    });
  }

  // Run on initial load and on Astro page transitions
  setup();
  document.addEventListener('astro:after-swap', setup);
</script>

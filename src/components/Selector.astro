---
interface Props {
  id: string;
  label?: string;
}

const { id, label } = Astro.props;
const hasLabel = Boolean(label?.trim());
---

<label class="selector" for={id}>
  <span class="selector__field">
    {hasLabel && <span class="selector__label">{label}</span>}
    <select class:list={['selector__control', { 'selector__control--with-label': hasLabel }]} id={id}>
      <slot />
    </select>
    <span class="selector__chevron" aria-hidden="true">
      <svg viewBox="0 0 24 24" fill="none">
        <path d="M5 9L12 16L19 9"></path>
      </svg>
    </span>
  </span>
</label>

<style>
  .selector {
    display: block;
    min-width: 180px;
  }

  .selector__label {
    position: absolute;
    top: 0.45rem;
    left: 0.875rem;
    z-index: 1;
    color: color-mix(in srgb, var(--sl-color-text) 68%, white 32%);
    font-size: 0.625rem;
    font-weight: 600;
    line-height: 1;
    pointer-events: none;
  }

  .selector__field {
    position: relative;
    display: flex;
    align-items: center;
  }

  .selector__control {
    width: 100%;
    height: 44px;
    min-height: 44px;
    padding: 0.5rem 2.5rem 0.5rem 0.875rem;
    border: 1px solid color-mix(in srgb, var(--sl-color-gray-4) 84%, transparent 16%);
    border-radius: 6px;
    background: linear-gradient(180deg, rgba(255, 255, 255, 0.88), rgba(248, 248, 248, 0.94));
    color: var(--sl-color-text);
    font-size: 0.875rem;
    font-weight: 500;
    line-height: 1.2;
    appearance: none;
    -webkit-appearance: none;
    box-sizing: border-box;
    cursor: pointer;
  }

  .selector__control--with-label {
    padding-top: 1.2rem;
    padding-bottom: 0.35rem;
  }

  .selector__control:focus {
    outline: none;
    border-color: var(--sl-color-accent);
    box-shadow: 0 0 0 3px color-mix(in srgb, var(--sl-color-accent) 14%, transparent 86%);
  }

  .selector__chevron {
    position: absolute;
    right: 0.875rem;
    top: 50%;
    width: 0.875rem;
    height: 0.875rem;
    transform: translateY(-50%);
    pointer-events: none;
    color: color-mix(in srgb, var(--sl-color-text) 72%, transparent 28%);
  }

  .selector__chevron svg {
    width: 100%;
    height: 100%;
    display: block;
  }

  .selector__chevron path {
    stroke: currentColor;
    stroke-width: 2.4;
    stroke-linecap: round;
    stroke-linejoin: round;
  }

  :global(:root[data-theme='dark']) .selector__label {
    color: color-mix(in srgb, var(--sl-color-text) 80%, white 20%);
  }

  :global(:root[data-theme='dark']) .selector__control {
    background: var(--sl-color-gray-6);
    border-color: color-mix(in srgb, var(--sl-color-gray-4) 82%, white 18%);
    color: var(--sl-color-white) !important;
    color-scheme: dark;
  }

  :global(:root[data-theme='dark']) .selector__field {
    color-scheme: dark;
  }

  :global(:root[data-theme='dark']) .selector__control option,
  :global(:root[data-theme='dark']) .selector__control optgroup {
    background-color: rgb(28, 28, 31) !important;
    color: var(--sl-color-white) !important;
  }

  :global(:root[data-theme='dark']) .selector__chevron {
    color: var(--sl-color-white);
  }

  @media (prefers-color-scheme: dark) {
    :global(:root:not([data-theme='light'])) .selector__label {
      color: color-mix(in srgb, var(--sl-color-text) 80%, white 20%);
    }

    :global(:root:not([data-theme='light'])) .selector__control {
      background-color: rgb(28, 28, 31) !important;
      background-image: linear-gradient(180deg, rgba(38, 38, 41, 0.9), rgba(28, 28, 31, 0.94));
      border-color: color-mix(in srgb, var(--sl-color-gray-4) 82%, white 18%);
      color: var(--sl-color-white) !important;
      color-scheme: dark;
    }

    :global(:root:not([data-theme='light'])) .selector__field {
      color-scheme: dark;
    }

    :global(:root:not([data-theme='light'])) .selector__control option,
    :global(:root:not([data-theme='light'])) .selector__control optgroup {
      background-color: rgb(28, 28, 31) !important;
      color: var(--sl-color-white) !important;
    }

    :global(:root:not([data-theme='light'])) .selector__chevron {
      color: var(--sl-color-white);
    }
  }

  @media (max-width: 900px) {
    .selector {
      min-width: 100%;
    }

    .selector__label {
      top: 0.45rem;
      left: 0.875rem;
    }

    .selector__control {
      height: 44px;
      min-height: 44px;
      padding: 0.5rem 2.5rem 0.5rem 0.875rem;
      border-radius: 6px;
      font-size: 0.875rem;
    }

    .selector__control--with-label {
      padding-top: 1.2rem;
      padding-bottom: 0.35rem;
    }

    .selector__chevron {
      width: 0.875rem;
      height: 0.875rem;
      right: 0.875rem;
    }
  }
</style>

---
interface Props {
  id: string;
  label?: string;
  placeholder?: string;
  type?: astroHTML.JSX.HTMLInputTypeAttribute;
}

const { id, label, placeholder = '', type = 'text' } = Astro.props;
const hasLabel = Boolean(label?.trim());
---

<label class="text-field" for={id}>
  <span class="text-field__field">
    {hasLabel && <span class="text-field__label">{label}</span>}
    <input
      class:list={['text-field__control', { 'text-field__control--with-label': hasLabel }]}
      id={id}
      type={type}
      placeholder={placeholder}
    />
  </span>
</label>

<style>
  .text-field {
    display: block;
    min-width: 180px;
  }

  .text-field__field {
    position: relative;
    display: flex;
    align-items: center;
  }

  .text-field__label {
    position: absolute;
    top: 0.45rem;
    left: 0.875rem;
    z-index: 1;
    color: color-mix(in srgb, var(--sl-color-text) 68%, white 32%);
    font-size: 0.625rem;
    font-weight: 600;
    line-height: 1;
    pointer-events: none;
  }

  .text-field__control {
    width: 100%;
    height: 44px;
    min-height: 44px;
    padding: 0.5rem 0.875rem;
    border: 1px solid color-mix(in srgb, var(--sl-color-gray-4) 84%, transparent 16%);
    border-radius: 6px;
    background: linear-gradient(180deg, rgba(255, 255, 255, 0.88), rgba(248, 248, 248, 0.94));
    color: var(--sl-color-text);
    font-size: 0.875rem;
    font-weight: 500;
    line-height: 1.2;
    box-sizing: border-box;
  }

  .text-field__control::placeholder {
    color: color-mix(in srgb, var(--sl-color-text) 56%, transparent 44%);
  }

  .text-field__control--with-label {
    padding-top: 1.2rem;
    padding-bottom: 0.35rem;
  }

  .text-field__control:focus {
    outline: none;
    border-color: var(--sl-color-accent);
    box-shadow: 0 0 0 3px color-mix(in srgb, var(--sl-color-accent) 14%, transparent 86%);
  }

  :global(:root[data-theme='dark']) .text-field__label {
    color: color-mix(in srgb, var(--sl-color-text) 80%, white 20%);
  }

  :global(:root[data-theme='dark']) .text-field__control {
    background: var(--sl-color-gray-6);
    border-color: color-mix(in srgb, var(--sl-color-gray-4) 82%, white 18%);
    color: var(--sl-color-white);
  }

  :global(:root[data-theme='dark']) .text-field__control::placeholder {
    color: color-mix(in srgb, var(--sl-color-white) 55%, transparent 45%);
  }

  @media (prefers-color-scheme: dark) {
    :global(:root:not([data-theme='light'])) .text-field__label {
      color: color-mix(in srgb, var(--sl-color-text) 80%, white 20%);
    }

    :global(:root:not([data-theme='light'])) .text-field__control {
      background-color: rgb(28, 28, 31);
      background-image: linear-gradient(180deg, rgba(38, 38, 41, 0.9), rgba(28, 28, 31, 0.94));
      border-color: color-mix(in srgb, var(--sl-color-gray-4) 82%, white 18%);
      color: var(--sl-color-white);
    }

    :global(:root:not([data-theme='light'])) .text-field__control::placeholder {
      color: color-mix(in srgb, var(--sl-color-white) 55%, transparent 45%);
    }
  }

  @media (max-width: 900px) {
    .text-field {
      min-width: 100%;
    }

    .text-field__label {
      top: 0.45rem;
      left: 0.875rem;
    }

    .text-field__control {
      height: 44px;
      min-height: 44px;
      padding: 0.5rem 0.875rem;
      border-radius: 6px;
      font-size: 0.875rem;
    }

    .text-field__control--with-label {
      padding-top: 1.2rem;
      padding-bottom: 0.35rem;
    }
  }
</style>

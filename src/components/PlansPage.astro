---
import allPricing from './PlansPageFeatures/PlansData/PlansModelData/v1.20.2/all-pricing--2026-04-24.json';
import ModelsTable from './ModelsTable.astro';
import Tooltip from './Tooltip.astro';
import { modelBrandIcons } from '../shared/lib/modelBrandIcons';

interface Props {
  selectedPlanId?: string;
}
const { selectedPlanId = '' } = Astro.props;

// Detect locale from URL path
const isDE = Astro.url.pathname.startsWith('/de/') || Astro.url.pathname === '/de';

const t = {
  ratePlansTitle: isDE ? 'Tarife' : 'Our Rate Plans',
  subtitle: isDE
    ? 'Die AI Foundation Services Plattform bietet eine nutzungsabhängige Preisgestaltung. Die Preise variieren je nach Modell, Vereinbarung und Tarif.'
    : 'Choose the commitment level that fits your workload. Your monthly base unlocks higher request limits and access to more powerful models. Need a custom setup or on-premises hosting?',
  thPlan: isDE ? 'Tarif' : 'Rate Plan',
  thBasePrice: isDE ? 'Grundpreis' : 'Base Price',
  thModelHost: isDE ? 'Modell-Hosting' : 'Model Host',
  thModelTier: isDE ? 'Modell-Tier' : 'Model Tier',
  thMinConsumption: isDE ? 'Mindestverbrauch' : 'Min. Consumption',
  thTokenPrice: isDE ? 'Input- / Output-Token-Preis' : 'Input / Output Token Price',
  thTokenPriceUnit: '€ / M Tokens',
  thRPM: isDE ? 'Beispiel RPM' : 'RPM',
  thRPMUnit: isDE ? 'Anfragen/Minute' : 'Requests/Minute',
  thRPMUnitShort: isDE ? 'Anfragen/Min' : 'Requests/Min',
  thCloud: isDE ? 'Cloud Anbieter' : 'Cloud',
  footnote: isDE
    ? '* Beispielpreise für T-Cloud-gehostete Large Language Models · † Beispiel-RPM für ein repräsentatives T-Cloud-Modell — genaue Limits variieren je Modell'
    : '* Example pricing for T-Cloud-hosted Large Language Models · † Example RPM for a representative T-Cloud model — exact limits vary by model',
  modelsTitle: isDE ? 'Unsere Modelle' : 'Our Models',
  modelsSubtitle: isDE
    ? 'Alle Tarife nutzen eine nutzungsbasierte Token-Abrechnung. Standard-Modelle sind leistungsfähig und auf Geschwindigkeit ausgelegt – zuverlässig für die meisten Anwendungsfälle, ohne Kompromisse bei der Qualität. Premium-Modelle gehen darüber hinaus: für komplexes Reasoning, lange Kontexte und Aufgaben, bei denen die Ausgabequalität im Vordergrund steht.'
    : 'All plans use pay-as-you-go token pricing. Standard models are capable and built for speed - reliable across most use cases, without cutting corners. Premium models go further: complex reasoning, long contexts, and tasks where output quality is the priority.',
  labelRatePlan: isDE ? 'Gewählter Tarif' : 'Rate Plan',
  labelSearch: isDE ? 'Suche' : 'Search',
  labelServerLocation: 'Server Location',
  labelCloud: isDE ? 'Cloud-Anbieter' : 'Cloud Provider',
  labelInputPriceRange: isDE ? 'Input-Preis' : 'Input Price',
  labelOutputPriceRange: isDE ? 'Output-Preis' : 'Output Price',
  placeholderSearch: isDE ? 'Modelle filtern...' : 'Filter models...',
  optionAll: isDE ? 'Alle' : 'All',
  priceUnder2: 'Under €2/MTok',
  price2to5: '€2-5/MTok',
  priceOver5: 'Over €5/MTok',
  thDPLocation: 'Data Processing Location',
  thCloudProvider: isDE ? 'Cloud-Anbieter' : 'Cloud Provider',
  thCreator: isDE ? 'Anbieter' : 'Creator',
  thModelName: isDE ? 'Modellname' : 'Model Name',
  thInputPrice: 'Input Token Price',
  thOutputPrice: 'Output Token Price',
  thTPM: 'TPM',
  thTPMUnit: 'Tokens/Min',
  thContextWindow: 'Context Window',
  thContextWindowUnit: 'Tokens',
  thLinks: 'Links',
  linkTermsOfUse: isDE ? 'Nutzungsbedingungen' : 'Terms of Use',
  linkDataProtection: isDE ? 'Datenschutz' : 'Data Protection',
  thHostingPlatform: 'Hosting Platform',
  thServerLocation: 'Server Location',
  thInputTokenLimit: 'Input Token Limit',
  thOutputTokenLimit: 'Output Token Limit',
  thRPMLimit: isDE ? 'RPM-Limit' : 'RPM Limit',
  noModels: isDE ? 'Keine Modelle gefunden.' : 'No models found.',
  euWorldwide: isDE ? 'EU & Weltweit' : 'EU & Worldwide',
  tooltipTCloud: isDE
    ? 'Gehostet auf der souveränen Infrastruktur der Telekom.'
    : "Hosted on Telekom's sovereign infrastructure.",
  tooltipExternal: isDE
    ? 'Gehostet bei Drittanbietern wie Microsoft Azure oder Google Cloud Platform.'
    : 'Hosted by third-party providers like Microsoft Azure or Google Cloud Platform.',
  tooltipStandard: isDE
    ? 'Leistungsfähige, schnelle und zuverlässige Modelle für die meisten Aufgaben.'
    : 'Capable, fast, and reliable models for most tasks.',
  tooltipPremium: isDE
    ? 'Leistungsstarke Modelle mit hoher Qualität für komplexe und kritische Anwendungsfälle.'
    : 'Powerful, high-capability models for complex and quality-critical work.',
};

const hostTooltips: Record<string, string> = {
  'T-Cloud': t.tooltipTCloud,
  External: t.tooltipExternal,
};

const tierTooltips: Record<string, string> = {
  Standard: t.tooltipStandard,
  Premium: t.tooltipPremium,
};

// Plan display config
const planConfigs = [
  {
    packageName: 'Essential',
    label: 'Essential',
    color: '#4de0af',
    basePrice: '1,000 \u20AC',
    tokenPrice: '0.20 / 0.65',
    rpm: '300',
    modelHost: ['T-Cloud', 'External'],
    modelTier: ['Standard'],
    isFilterAvailable: true,
  },
  {
    packageName: 'Professional',
    label: 'Professional',
    color: '#4ad9cd',
    basePrice: '3,000 \u20AC',
    tokenPrice: '0.20 / 0.65',
    rpm: '1000',
    modelHost: ['T-Cloud', 'External'],
    modelTier: ['Standard', 'Premium'],
    isFilterAvailable: true,
  },
  {
    packageName: 'Agentic',
    label: 'Agentic',
    color: '#4dd1e0',
    basePrice: '5,000 \u20AC',
    tokenPrice: '0.20 / 0.65',
    rpm: '3000',
    modelHost: ['T-Cloud', 'External'],
    modelTier: ['Standard', 'Premium'],
    isFilterAvailable: true,
  },
  {
    packageName: 'Tarif Standard3000 Template',
    label: 'Enterprise',
    color: '#5ec2ed',
    basePrice: 'Custom',
    tokenPrice: '0.20 / 0.65',
    rpm: 'Custom',
    modelHost: ['T-Cloud', 'External'],
    modelTier: ['Standard', 'Premium'],
    isFilterAvailable: false,
  },
];

// Helper: parse deployment region
function parseCloud(deploymentRegion: string): string {
  const lower = deploymentRegion.toLowerCase();
  const provider = lower.split('-')[0];
  if (provider === 'otc') return 'T-Cloud';
  if (provider === 'azure') return 'Azure';
  if (provider === 'gcp') return 'GCP';
  return deploymentRegion;
}

function parseModelHost(deploymentRegion: string): string {
  return deploymentRegion.toLowerCase().startsWith('otc-') ? 'T-Cloud' : 'External';
}

function parseCloudProvider(deploymentRegion: string): string {
  const lower = deploymentRegion.toLowerCase();
  const provider = lower.split('-')[0];
  if (provider === 'otc') return 'Telekom';
  if (provider === 'azure') return 'Azure';
  if (provider === 'gcp') return 'GCP';
  return deploymentRegion;
}

function parseModelCreator(exactModelName: string | undefined, displayModelName: string): string {
  const source = `${exactModelName || ''} ${displayModelName}`.toLowerCase();
  const isOpenAIOSeries = /\bo\d+(?:[.-]|\b)/.test(source);
  const isOpenAIAdaSeries = /\b(?:embedding\s+ada|text-embedding-ada|ada(?:[-\s]?\d+)?)\b/.test(source);

  if (source.includes('claude')) return 'Anthropic';
  if (source.includes('gemini')) return 'Google';
  if (
    source.includes('gpt') ||
    isOpenAIOSeries ||
    isOpenAIAdaSeries ||
    source.includes('codex') ||
    source.includes('whisper')
  )
    return 'OpenAI';
  if (source.includes('llama') || source.includes('meta')) return 'Meta';
  if (source.includes('mistral')) return 'Mistral';
  if (source.includes('qwen')) return 'Alibaba Cloud';
  if (source.includes('jina')) return 'Jina AI';
  if (source.includes('bge')) return 'BAAI';
  if (source.includes('teuken') || source.includes('tsi') || source.includes('col qwen')) return 'T-Systems';

  return 'Other';
}

function parseModelTier(
  exactModelName: string | undefined,
  displayModelName: string,
  inputPrice: number,
  outputPrice: number,
): string {
  const source = `${exactModelName || ''} ${displayModelName}`.toLowerCase();

  const premiumPatterns = [
    'claude',
    'sonnet',
    'opus',
    'gpt 5',
    'gpt-5',
    'gpt 4.1',
    'gpt-4.1',
    'gpt 4o',
    'gpt-4o',
    'o1',
    'o3',
    'gemini 2.5 pro',
    'gemini 3 pro',
    'mistral large',
    'mistral medium',
  ];

  const standardExclusions = ['mini', 'nano', 'flash', 'embedding', 'embeddings', 'whisper'];

  if (
    premiumPatterns.some((pattern) => source.includes(pattern)) &&
    !standardExclusions.some((pattern) => source.includes(pattern))
  ) {
    return 'Premium';
  }

  if (inputPrice >= 5 || outputPrice >= 10) {
    return 'Premium';
  }

  return 'Standard';
}

const COUNTRY_CODES: Record<string, string> = {
  germany: 'de',
  sweden: 'se',
  france: 'fr',
  europe: 'eu',
  us: 'us',
};

function parseLocation(deploymentRegion: string): { name: string; code: string } {
  const parts = deploymentRegion.toLowerCase().split('-');
  if (parts.length < 2) return { name: deploymentRegion, code: '' };
  const raw = parts[1];
  const name = raw.charAt(0).toUpperCase() + raw.slice(1);
  const code = COUNTRY_CODES[raw] || '';
  return { name, code };
}

function mapModelRow(
  model: any,
  fallbackModel: any,
  modelHost: string,
  cloudProvider: string,
  serverLocation: string,
  locationCode: string,
  isSubRow: boolean,
) {
  const exactModelName = model.exactModelName ?? fallbackModel.exactModelName;
  const displayName = model.displayModelName || fallbackModel.displayModelName;

  return {
    modelHost,
    cloudProvider,
    creator: parseModelCreator(exactModelName, displayName),
    exactModelName: model.exactModelName,
    modelTier: parseModelTier(
      exactModelName,
      displayName,
      model.inputPricePerMillionTokens ?? fallbackModel.inputPricePerMillionTokens,
      model.outputPricePerMillionTokens ?? fallbackModel.outputPricePerMillionTokens,
    ),
    displayName,
    subName: model.modelLabel || '',
    inputPrice: model.inputPricePerMillionTokens ?? fallbackModel.inputPricePerMillionTokens,
    outputPrice: model.outputPricePerMillionTokens ?? fallbackModel.outputPricePerMillionTokens,
    tpm: model.inputTokenPerMinuteLimit ?? fallbackModel.inputTokenPerMinuteLimit,
    contextWindow: model.contextWindow ?? fallbackModel.contextWindow ?? null,
    termsOfUseUrl: model.termsOfUseUrl ?? fallbackModel.termsOfUseUrl ?? '',
    dataProtectionUrl: model.dataProtectionUrl ?? fallbackModel.dataProtectionUrl ?? '',
    serverLocation,
    locationCode,
    inputTokenMin: model.inputTokenPerMinuteLimit ?? fallbackModel.inputTokenPerMinuteLimit,
    outputTokenMin: model.outputTokenPerMinuteLimit ?? fallbackModel.outputTokenPerMinuteLimit,
    rpm: model.requestPerMinuteLimit ?? fallbackModel.requestPerMinuteLimit,
    isSubRow,
  };
}

// Build plan data for client-side use
const plansData = allPricing
  .map((plan: any) => {
    const config = planConfigs.find((c) => c.packageName === plan.packageName);
    // On the index page, where no specific plan is selected, ignore packages that are not present
    // in planConfigs. This keeps the page scoped to filterable plans only, so the initial filter
    // state and selected plan index are derived from the same plan set.
    if (!selectedPlanId && (!config || !config.isFilterAvailable)) return null;
    if (selectedPlanId && plan.packageName !== selectedPlanId) return null;
    const models = (plan.modelQuotaConfigs || [])
      .map((m: any) => {
        const modelHost = parseModelHost(m.deploymentRegion);
        const cloudProvider = parseCloudProvider(m.deploymentRegion);
        const { name: locName, code: locCode } = parseLocation(m.deploymentRegion);
        const rows: any[] = [mapModelRow(m, m, modelHost, cloudProvider, locName, locCode, false)];
        if (m.modelQuotaMetadata?.data) {
          for (const sub of m.modelQuotaMetadata.data) {
            rows.push(mapModelRow(sub, m, modelHost, cloudProvider, locName, locCode, true));
          }
        }
        return rows;
      })
      .flat();
    return {
      packageName: plan.packageName,
      isFilterAvailable: config?.isFilterAvailable,
      label: config?.label || plan.packageName,
      models,
    };
  })
  .filter(Boolean);

const showRatePlans = !selectedPlanId;
const initialPlanIndex = selectedPlanId ? plansData.findIndex((p: any) => p.packageName === selectedPlanId) : 0;
---

<div class="plans-page">
  {
    showRatePlans && (
      <section class="rate-plans-section">
        <h2>{t.ratePlansTitle}</h2>
        <p class="par-description">{t.subtitle}</p>
        <div class="table-wrapper">
          <table class="plans-table">
            <thead>
              <tr>
                <th>{t.thPlan}</th>
                <th>{t.thBasePrice}</th>
                <th>
                  {t.thTokenPrice}
                  <div class="plans-table__small-text">{t.thTokenPriceUnit}</div>
                </th>
                <th>
                  {t.thRPM}
                  <div class="plans-table__small-text">{t.thRPMUnit}</div>
                </th>
                <th>{t.thModelHost}</th>
                <th>{t.thModelTier}</th>
              </tr>
            </thead>
            <tbody>
              {planConfigs.map((plan) => (
                <tr>
                  <td>
                    <span class="plans-tag" style={`background:${plan.color};color:#000`}>
                      {plan.label}
                    </span>
                  </td>
                  <td>
                    <span class="plans-table__main-text">{plan.basePrice}</span>
                  </td>
                  <td>{plan.tokenPrice}</td>
                  <td>{plan.rpm}</td>
                  <td>
                    {plan.modelHost.map((cloud, i) => (
                      <>
                        {i > 0 && ' '}
                        <Tooltip text={hostTooltips[cloud] || cloud} maxWidth="26rem">
                          <span class={`plans-tag ${cloud === 'T-Cloud' ? 'tag-tcloud' : 'tag-cloud'}`}>{cloud}</span>
                        </Tooltip>
                      </>
                    ))}
                  </td>
                  <td>
                    {plan.modelTier.map((tier, i) => (
                      <>
                        {i > 0 && ' '}
                        <Tooltip text={tierTooltips[tier] || tier} maxWidth="24rem">
                          <span class={`plans-tag ${tier === 'Premium' ? 'tag-premium' : 'tag-tier'}`}>{tier}</span>
                        </Tooltip>
                      </>
                    ))}
                  </td>
                </tr>
              ))}
            </tbody>
          </table>
          <small>{t.footnote}</small>
          <br />
          <small>
            <a href={isDE ? '/de/reference/rate-limits' : '/reference/rate-limits'}>
              {isDE ? 'Mehr zu Rate-Limits →' : 'Learn more about rate limits →'}
            </a>
          </small>
        </div>
      </section>
    )
  }

  <ModelsTable
    plansData={plansData}
    effectiveIndex={initialPlanIndex}
    locked={Boolean(selectedPlanId)}
    translations={t}
    modelBrandIcons={modelBrandIcons}
    hostTooltips={hostTooltips}
    tierTooltips={tierTooltips}
  />
</div>

<script>
  function initPlansPageLayout() {
    const container = document.querySelector('.plans-page') as HTMLElement;
    if (!container) return;

    // Mark the title's content panel so CSS can target it
    const contentPanel = container.closest('.content-panel');
    const titlePanel = contentPanel?.previousElementSibling;
    if (titlePanel?.classList.contains('content-panel')) {
      titlePanel.classList.add('plans-title-panel');
    }

    // Tell the header grid to lay out as if there's a right sidebar,
    // since our content margin already mimics that alignment.
    document.documentElement.setAttribute('data-has-toc', '');
  }

  // Run on initial load and on Astro page transitions
  document.addEventListener('astro:page-load', initPlansPageLayout);
  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', initPlansPageLayout);
  } else {
    initPlansPageLayout();
  }
</script>

<style is:global>
  .plans-page {
    width: 100%;
    --model-link-color: #4f5cff;
    --model-link-icon-color: #000000;
  }

  :root[data-theme='dark'] .plans-page {
    --model-link-color: #7d87ff;
    --model-link-icon-color: #7d87ff;
  }

  .rate-plans-section {
    margin-bottom: 2rem;
  }

  .table-wrapper {
    width: fit-content;
    overflow: visible;
  }

  .table-wrapper > table {
    border-radius: var(--sl-border-md);
    overflow: visible;
  }

  .par-description {
    width: min(100%, 54rem);
  }

  .plans-table {
    border-collapse: collapse;
    font-size: 0.8rem;
    overflow-wrap: break-word;
  }

  .plans-table th,
  .plans-table td {
    border: 0;
    padding: 0.85rem 1.35rem;
    text-align: left;
  }

  .plans-table th {
    background: var(--sl-color-gray-6);
    cursor: pointer;
    user-select: none;
    vertical-align: middle;
  }

  .plans-table__small-text {
    font-weight: normal;
    font-size: var(--sl-text-2xs);
  }

  .plans-table__main-text {
    font-weight: 650;
  }

  .plans-table tbody tr:hover {
    background: var(--sl-color-gray-6);
  }

  .plans-table thead tr {
    border-bottom: 1px solid var(--sl-color-gray-5);
  }

  .plans-table tbody tr {
    border-bottom: 1px solid var(--sl-color-gray-5);
  }

  .plans-table tbody tr:last-child {
    border-bottom: 0;
  }

  .plans-table tbody tr.sub-row {
    opacity: 0.85;
    font-size: 0.85rem;
  }

  .plans-tag {
    display: inline-block;
    padding: 0.15rem 0.5rem;
    border-radius: 4px;
    font-size: 0.8rem;
    font-weight: 600;
    white-space: nowrap;
  }

  .plans-tag:hover {
    cursor: pointer;
  }

  .tag-tcloud {
    background: #e20074 !important;
    color: white !important;
  }

  .tag-cloud {
    background: var(--sl-color-gray-5);
    color: var(--sl-color-white);
  }

  .tag-tier {
    background: color-mix(in srgb, var(--sl-color-gray-5) 72%, white 28%);
    color: var(--sl-color-text);
  }

  .tag-premium {
    background: rgba(78, 201, 223, 0.28);
    color: #238fa5;
    box-shadow: inset 0 0 0 1px rgba(78, 201, 223, 0.22);
  }

  .sort-icon {
    font-size: 1rem;
    margin-left: 0.25rem;
    opacity: 0.5;
  }

  .sort-icon.active {
    color: #e20074;
    opacity: 1;
  }

  @media (max-width: 1200px) {
    .par-description {
      width: min(100%, 46rem);
    }
  }

  @media (max-width: 900px) {
    .par-description {
      width: 100%;
    }
  }
</style>

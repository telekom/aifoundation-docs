---
import 'flag-icons/css/flag-icons.min.css';
import allPricing from './PlansPageFeatures/PlansData/PlansModelData/v1.20.2/all-pricing--2026-01-19.json';
import countryData from '../shared/lib/countryCodeWithFlags.json';
import Tooltip from './Tooltip.astro';
import { modelBrandIcons } from '../shared/lib/modelBrandIcons';

interface Props {
  selectedPlanId?: string;
}
const { selectedPlanId = '' } = Astro.props;

// Detect locale from URL path
const isDE = Astro.url.pathname.startsWith('/de/') || Astro.url.pathname === '/de';

const t = {
  ratePlansTitle: isDE ? 'Tarife' : 'Our Rate Plans',
  subtitle: isDE
    ? 'Die AI Foundation Services Plattform bietet eine nutzungsabhängige Preisgestaltung. Die Preise variieren je nach Modell, Vereinbarung und Tarif.'
    : 'Choose the commitment level that fits your workload. Your monthly base unlocks higher request limits and access to more powerful models. Need a custom setup or on-premises hosting?',
  // subtitle2: isDE
  //   ? 'Bitte kontaktieren Sie uns für weitere Informationen zu den dedizierten und on-premises Hosting-Optionen.'
  //   : 'Please contact us for more information on the dedicated and on-premises hosting options.',
  thPlan: isDE ? 'Tarif' : 'Rate Plan',
  thBasePrice: isDE ? 'Grundpreis' : 'Base Price',
  thModelHost: isDE ? 'Modell-Hosting' : 'Model Host',
  thModelTier: isDE ? 'Modell-Tier' : 'Model Tier',
  thMinConsumption: isDE ? 'Mindestverbrauch' : 'Min. Consumption',
  thTokenPrice: isDE ? 'Input- / Output-Token-Preis' : 'Input / Output Token Price',
  thTokenPriceUnit: '€ / M Tokens',
  thRPM: isDE ? 'Beispiel RPM' : 'RPM',
  thRPMUnit: isDE ? 'Anfragen/Minute' : 'Requests/Minute',
  thRPMUnitShort: isDE ? 'Anfragen/Min' : 'Requests/Min',
  thCloud: isDE ? 'Cloud Anbieter' : 'Cloud',
  footnote: isDE
    ? '* Beispielpreise für T-Cloud-gehostete Large Language Models · † Beispiel-RPM für ein repräsentatives T-Cloud-Modell — genaue Limits variieren je Modell'
    : '* Example pricing for T-Cloud-hosted Large Language Models · † Example RPM for a representative T-Cloud model — exact limits vary by model',
  modelsTitle: isDE ? 'Unsere Modelle' : 'Our Models',
  modelsSubtitle: isDE
    ? 'Alle Tarife nutzen eine nutzungsbasierte Token-Abrechnung. Standard-Modelle sind leistungsfähig und auf Geschwindigkeit ausgelegt – zuverlässig für die meisten Anwendungsfälle, ohne Kompromisse bei der Qualität. Premium-Modelle gehen darüber hinaus: für komplexes Reasoning, lange Kontexte und Aufgaben, bei denen die Ausgabequalität im Vordergrund steht.'
    : 'All plans use pay-as-you-go token pricing. Standard models are capable and built for speed - reliable across most use cases, without cutting corners. Premium models go further: complex reasoning, long contexts, and tasks where output quality is the priority.',
  labelRatePlan: isDE ? 'Gewählter Tarif' : 'Rate Plan',
  labelSearch: isDE ? 'Suche' : 'Search',
  labelServerLocation: 'Server Location',
  labelCloud: 'Cloud',
  labelPriceRange: 'Price Range',
  placeholderSearch: isDE ? 'Modelle filtern...' : 'Filter models...',
  optionAll: isDE ? 'Alle' : 'All',
  priceUnder2: 'Under €2/MTok',
  price2to5: '€2-5/MTok',
  priceOver5: 'Over €5/MTok',
  thDPLocation: 'Data Processing Location',
  thCloudProvider: isDE ? 'Cloud-Anbieter' : 'Cloud Provider',
  thCreator: isDE ? 'Anbieter' : 'Creator',
  thModelName: isDE ? 'Modellname' : 'Model Name',
  thInputPrice: 'Input Token Price',
  thOutputPrice: 'Output Token Price',
  thTPM: 'TPM',
  thTPMUnit: 'Tokens/Min',
  thContextWindow: 'Context Window',
  thContextWindowUnit: 'Tokens',
  thLinks: 'Links',
  linkTermsOfUse: isDE ? 'Nutzungsbedingungen' : 'Terms of Use',
  linkDataProtection: isDE ? 'Datenschutz' : 'Data Protection',
  thHostingPlatform: 'Hosting Platform',
  thServerLocation: 'Server Location',
  thInputTokenLimit: 'Input Token Limit',
  thOutputTokenLimit: 'Output Token Limit',
  thRPMLimit: isDE ? 'RPM-Limit' : 'RPM Limit',
  noModels: isDE ? 'Keine Modelle gefunden.' : 'No models found.',
  euWorldwide: isDE ? 'EU & Weltweit' : 'EU & Worldwide',
  tooltipTCloud: isDE
    ? 'Gehostet auf der souveränen Infrastruktur der Telekom.'
    : "Hosted on Telekom's sovereign infrastructure.",
  tooltipExternal: isDE
    ? 'Gehostet bei Drittanbietern wie Microsoft Azure oder Google Cloud Platform.'
    : 'Hosted by third-party providers like Microsoft Azure or Google Cloud Platform.',
  tooltipStandard: isDE
    ? 'Leistungsfähige, schnelle und zuverlässige Modelle für die meisten Aufgaben.'
    : 'Capable, fast, and reliable models for most tasks.',
  tooltipPremium: isDE
    ? 'Leistungsstarke Modelle mit hoher Qualität für komplexe und kritische Anwendungsfälle.'
    : 'Powerful, high-capability models for complex and quality-critical work.',
};

const hostTooltips: Record<string, string> = {
  'T-Cloud': t.tooltipTCloud,
  External: t.tooltipExternal,
};

const tierTooltips: Record<string, string> = {
  Standard: t.tooltipStandard,
  Premium: t.tooltipPremium,
};

// Plan display config
const planConfigs = [
  { packageName: 'Tarif Basic Template',         label: 'Essential',    color: '#4de0af', basePrice: '1,000 \u20AC', tokenPrice: '0.20 / 0.65', rpm: '300',    modelHost: ['T-Cloud', 'External'], modelTier: ['Standard'] },
  { packageName: 'Tarif Standard1000 Template',  label: 'Professional', color: '#4ad9cd', basePrice: '3,000 \u20AC', tokenPrice: '0.20 / 0.65', rpm: '1000',   modelHost: ['T-Cloud', 'External'], modelTier: ['Standard', 'Premium'] },
  { packageName: 'Tarif Standard2000 Template',  label: 'Agentic',      color: '#4dd1e0', basePrice: '5,000 \u20AC', tokenPrice: '0.20 / 0.65', rpm: '3000',   modelHost: ['T-Cloud', 'External'], modelTier: ['Standard', 'Premium'] },
  { packageName: 'Tarif Standard3000 Template',  label: 'Enterprise',   color: '#5ec2ed', basePrice: 'Custom',      tokenPrice: '0.20 / 0.65', rpm: 'Custom', modelHost: ['T-Cloud', 'External'], modelTier: ['Standard', 'Premium'] },
];

// Helper: parse deployment region
function parseCloud(deploymentRegion: string): string {
  const lower = deploymentRegion.toLowerCase();
  const provider = lower.split('-')[0];
  if (provider === 'otc') return 'T-Cloud';
  if (provider === 'azure') return 'Azure';
  if (provider === 'gcp') return 'GCP';
  return deploymentRegion;
}

function parseModelHost(deploymentRegion: string): string {
  return deploymentRegion.toLowerCase().startsWith('otc-') ? 'T-Cloud' : 'External';
}

function parseCloudProvider(deploymentRegion: string): string {
  const lower = deploymentRegion.toLowerCase();
  const provider = lower.split('-')[0];
  if (provider === 'otc') return 'Open Telekom Cloud';
  if (provider === 'azure') return 'Microsoft Azure';
  if (provider === 'gcp') return 'Google Cloud Platform';
  return deploymentRegion;
}

function parseModelCreator(exactModelName: string | undefined, displayModelName: string): string {
  const source = `${exactModelName || ''} ${displayModelName}`.toLowerCase();

  if (source.includes('claude')) return 'Anthropic';
  if (source.includes('gemini')) return 'Google';
  if (source.includes('gpt') || source.includes('o1') || source.includes('o3') || source.includes('codex') || source.includes('whisper')) return 'OpenAI';
  if (source.includes('llama') || source.includes('meta')) return 'Meta';
  if (source.includes('mistral')) return 'Mistral';
  if (source.includes('qwen')) return 'Alibaba Cloud';
  if (source.includes('jina')) return 'Jina AI';
  if (source.includes('bge')) return 'BAAI';
  if (source.includes('teuken') || source.includes('tsi') || source.includes('col qwen')) return 'T-Systems';

  return 'Other';
}

function parseModelTier(
  exactModelName: string | undefined,
  displayModelName: string,
  inputPrice: number,
  outputPrice: number,
): string {
  const source = `${exactModelName || ''} ${displayModelName}`.toLowerCase();

  const premiumPatterns = [
    'claude',
    'sonnet',
    'opus',
    'gpt 5',
    'gpt-5',
    'gpt 4.1',
    'gpt-4.1',
    'gpt 4o',
    'gpt-4o',
    'o1',
    'o3',
    'gemini 2.5 pro',
    'gemini 3 pro',
    'mistral large',
    'mistral medium',
  ];

  const standardExclusions = ['mini', 'nano', 'flash', 'embedding', 'embeddings', 'whisper'];

  if (premiumPatterns.some(pattern => source.includes(pattern)) && !standardExclusions.some(pattern => source.includes(pattern))) {
    return 'Premium';
  }

  if (inputPrice >= 5 || outputPrice >= 10) {
    return 'Premium';
  }

  return 'Standard';
}

const COUNTRY_CODES: Record<string, string> = {
  germany: 'de', sweden: 'se', france: 'fr', europe: 'eu', us: 'us',
};

function parseLocation(deploymentRegion: string): { name: string; code: string } {
  const parts = deploymentRegion.toLowerCase().split('-');
  if (parts.length < 2) return { name: deploymentRegion, code: '' };
  const raw = parts[1];
  const name = raw.charAt(0).toUpperCase() + raw.slice(1);
  const code = COUNTRY_CODES[raw] || '';
  return { name, code };
}

function mapModelRow(
  model: any,
  fallbackModel: any,
  modelHost: string,
  cloudProvider: string,
  serverLocation: string,
  locationCode: string,
  isSubRow: boolean,
) {
  const exactModelName = model.exactModelName ?? fallbackModel.exactModelName;
  const displayName = model.displayModelName || fallbackModel.displayModelName;

  return {
    modelHost,
    cloudProvider,
    creator: parseModelCreator(exactModelName, displayName),
    modelTier: parseModelTier(
      exactModelName,
      displayName,
      model.inputPricePerMillionTokens ?? fallbackModel.inputPricePerMillionTokens,
      model.outputPricePerMillionTokens ?? fallbackModel.outputPricePerMillionTokens,
    ),
    displayName,
    subName: model.modelLabel || '',
    inputPrice: model.inputPricePerMillionTokens ?? fallbackModel.inputPricePerMillionTokens,
    outputPrice: model.outputPricePerMillionTokens ?? fallbackModel.outputPricePerMillionTokens,
    tpm: model.inputTokenPerMinuteLimit ?? fallbackModel.inputTokenPerMinuteLimit,
    contextWindow: model.contextWindow ?? fallbackModel.contextWindow ?? null,
    termsOfUseUrl: model.termsOfUseUrl ?? fallbackModel.termsOfUseUrl ?? '',
    dataProtectionUrl: model.dataProtectionUrl ?? fallbackModel.dataProtectionUrl ?? '',
    serverLocation,
    locationCode,
    inputTokenMin: model.inputTokenPerMinuteLimit ?? fallbackModel.inputTokenPerMinuteLimit,
    outputTokenMin: model.outputTokenPerMinuteLimit ?? fallbackModel.outputTokenPerMinuteLimit,
    rpm: model.requestPerMinuteLimit ?? fallbackModel.requestPerMinuteLimit,
    isSubRow,
  };
}

// Build plan data for client-side use
const plansData = allPricing.map((plan: any) => {
  const config = planConfigs.find(c => c.packageName === plan.packageName);
  const models = (plan.modelQuotaConfigs || []).map((m: any) => {
    const modelHost = parseModelHost(m.deploymentRegion);
    const cloudProvider = parseCloudProvider(m.deploymentRegion);
    const { name: locName, code: locCode } = parseLocation(m.deploymentRegion);
    const rows: any[] = [mapModelRow(m, m, modelHost, cloudProvider, locName, locCode, false)];
    if (m.modelQuotaMetadata?.data) {
      for (const sub of m.modelQuotaMetadata.data) {
        rows.push(mapModelRow(sub, m, modelHost, cloudProvider, locName, locCode, true));
      }
    }
    return rows;
  }).flat();
  return {
    packageName: plan.packageName,
    label: config?.label || plan.packageName,
    models,
  };
});

const showRatePlans = !selectedPlanId;
const initialPlanIndex = selectedPlanId
  ? plansData.findIndex((p: any) => p.packageName === selectedPlanId)
  : 0;
const effectiveIndex = initialPlanIndex >= 0 ? initialPlanIndex : 0;
---

<div class="plans-page" data-plans={JSON.stringify(plansData)} data-brand-icons={JSON.stringify(modelBrandIcons)} data-host-tooltips={JSON.stringify(hostTooltips)} data-tier-tooltips={JSON.stringify(tierTooltips)} data-initial-index={effectiveIndex} data-locked={selectedPlanId ? 'true' : 'false'} data-t={JSON.stringify(t)}>

  {showRatePlans && (
    <section class="rate-plans-section">
      <h2>{t.ratePlansTitle}</h2>
      <p class="par-description">{t.subtitle}</p>
      {/* <p>{t.subtitle2}</p> */}
      <div class="table-wrapper">
        <table class="plans-table">
          <thead>
            <tr>
              <th>{t.thPlan}</th>
              <th>{t.thBasePrice}</th>
              <th>{t.thTokenPrice}<div class="plans-table__small-text">{t.thTokenPriceUnit}</div></th>
              <th>{t.thRPM}<div class="plans-table__small-text">{t.thRPMUnit}</div></th>
              <th>{t.thModelHost}</th>
              <th>{t.thModelTier}</th>
            </tr>
          </thead>
          <tbody>
            {planConfigs.map(plan => (
              <tr>
                <td>
                  <span class="plans-tag" style={`background:${plan.color};color:#000`}>
                    {plan.label}
                  </span>
                </td>
                <td><span class="plans-table__main-text">{plan.basePrice}</span></td>
                <td>{plan.tokenPrice}</td>
                <td>{plan.rpm}</td>
                <td>
                  {plan.modelHost.map((cloud, i) => (
                    <>
                      {i > 0 && ' '}
                      <Tooltip text={hostTooltips[cloud] || cloud} maxWidth="26rem">
                        <span class={`plans-tag ${cloud === 'T-Cloud' ? 'tag-tcloud' : 'tag-cloud'}`}>
                          {cloud}
                        </span>
                      </Tooltip>
                    </>
                  ))}
                </td>
                <td>
                  {plan.modelTier.map((tier, i) => (
                    <>
                      {i > 0 && ' '}
                      <Tooltip text={tierTooltips[tier] || tier} maxWidth="24rem">
                        <span class={`plans-tag ${tier === 'Premium' ? 'tag-premium' : 'tag-tier'}`}>
                          {tier}
                        </span>
                      </Tooltip>
                    </>
                  ))}
                </td>
              </tr>
            ))}
          </tbody>
        </table>
        <small>{t.footnote}</small>
        <br/>
        <small>
          <a href={isDE ? '/de/reference/rate-limits' : '/reference/rate-limits'}>
            {isDE ? 'Mehr zu Rate-Limits →' : 'Learn more about rate limits →'}
          </a>
        </small>
      </div>
    </section>
  )}

  <section class="models-section">
    <h2>{t.modelsTitle}</h2>
    <p class="par-description">{t.modelsSubtitle}</p>

    <div class="models-controls">
      {!selectedPlanId && (
        <div class="control-group">
          <label for="plan-selector">{t.labelRatePlan}</label>
          <select id="plan-selector">
            {plansData.map((plan: any, i: number) => (
              <option value={i} selected={i === effectiveIndex}>
                {plan.label}
              </option>
            ))}
          </select>
        </div>
      )}
      <div class="control-group">
        <label for="model-search">{t.labelSearch}</label>
        <input type="text" id="model-search" placeholder={t.placeholderSearch} />
      </div>
      <div class="control-group">
        <label for="location-filter">{t.labelServerLocation}</label>
        <select id="location-filter">
          <option value="">{t.optionAll}</option>
        </select>
      </div>
      <div class="control-group">
        <label for="cloud-filter">{t.labelCloud}</label>
        <select id="cloud-filter">
          <option value="">{t.optionAll}</option>
        </select>
      </div>
      <div class="control-group">
        <label for="price-filter">{t.labelPriceRange}</label>
        <select id="price-filter">
          <option value="">{t.optionAll}</option>
          <option value="0-2">{t.priceUnder2}</option>
          <option value="2-5">{t.price2to5}</option>
          <option value="5+">{t.priceOver5}</option>
        </select>
      </div>
    </div>

    <div class="table-wrapper">
      <table class="plans-table" id="models-table">
        <thead>
          <tr>
            <th data-sort="modelHost">{t.thModelHost}</th>
            <th data-sort="cloudProvider">{t.thCloudProvider}</th>
            <th data-sort="modelTier">{t.thModelTier}</th>
            <th data-sort="creator">{t.thCreator}</th>
            <th data-sort="displayName">{t.thModelName}</th>
            <th data-sort="inputPrice">{t.thInputPrice}<div class="plans-table__small-text">M Tokens</div></th>
            <th data-sort="outputPrice">{t.thOutputPrice}<div class="plans-table__small-text">M Tokens</div></th>
            <th data-sort="serverLocation">{t.thServerLocation}</th>
            <th data-sort="rpm">{t.thRPMLimit}<div class="plans-table__small-text">{t.thRPMUnitShort}</div></th>
            <th data-sort="tpm">{t.thTPM}<div class="plans-table__small-text">{t.thTPMUnit}</div></th>
            <th data-sort="contextWindow">{t.thContextWindow}<div class="plans-table__small-text">{t.thContextWindowUnit}</div></th>
            <th>{t.thLinks}</th>
          </tr>
        </thead>
        <tbody id="models-tbody">
          <!-- Populated by client-side script -->
        </tbody>
      </table>
    </div>
  </section>
</div>

<script>
  function initPlansPage() {
    const container = document.querySelector('.plans-page') as HTMLElement;
    if (!container) return;

    // Mark the title's content panel so CSS can target it
    const contentPanel = container.closest('.content-panel');
    const titlePanel = contentPanel?.previousElementSibling;
    if (titlePanel?.classList.contains('content-panel')) {
      titlePanel.classList.add('plans-title-panel');
    }

    // Tell the header grid to lay out as if there's a right sidebar,
    // since our content margin already mimics that alignment.
    document.documentElement.setAttribute('data-has-toc', '');

    const plansData = JSON.parse(container.dataset.plans || '[]');
    const brandIcons = JSON.parse(container.dataset.brandIcons || '{}');
    const hostTooltips = JSON.parse(container.dataset.hostTooltips || '{}');
    const tierTooltips = JSON.parse(container.dataset.tierTooltips || '{}');
    const translations = JSON.parse(container.dataset.t || '{}');
    let currentIndex = parseInt(container.dataset.initialIndex || '0', 10);
    const locked = container.dataset.locked === 'true';

    const selector = document.getElementById('plan-selector') as HTMLSelectElement | null;
    const searchInput = document.getElementById('model-search') as HTMLInputElement | null;
    const locationFilter = document.getElementById('location-filter') as HTMLSelectElement | null;
    const cloudFilter = document.getElementById('cloud-filter') as HTMLSelectElement | null;
    const priceFilter = document.getElementById('price-filter') as HTMLSelectElement | null;
    const tbody = document.getElementById('models-tbody') as HTMLTableSectionElement | null;
    const table = document.getElementById('models-table') as HTMLTableElement | null;

    let sortKey = '';
    let sortAsc = true;
    let searchTerm = '';

    function populateFilterDropdowns() {
      const plan = plansData[currentIndex];
      if (!plan) return;

      const locations = new Set<string>();
      const clouds = new Set<string>();
      for (const m of plan.models) {
        if (m.serverLocation) locations.add(m.serverLocation);
        if (m.cloudProvider) clouds.add(m.cloudProvider);
      }

      if (locationFilter) {
        const current = locationFilter.value;
        locationFilter.innerHTML = `<option value="">${translations.optionAll || 'All'}</option>`;
        [...locations].sort().forEach(loc => {
          const opt = document.createElement('option');
          opt.value = loc;
          opt.textContent = loc;
          if (loc === current) opt.selected = true;
          locationFilter.appendChild(opt);
        });
      }

      if (cloudFilter) {
        const current = cloudFilter.value;
        cloudFilter.innerHTML = `<option value="">${translations.optionAll || 'All'}</option>`;
        [...clouds].sort().forEach(c => {
          const opt = document.createElement('option');
          opt.value = c;
          opt.textContent = c;
          if (c === current) opt.selected = true;
          cloudFilter.appendChild(opt);
        });
      }
    }

    function getModels() {
      const plan = plansData[currentIndex];
      if (!plan) return [];
      let models = [...plan.models];

      if (searchTerm) {
        const term = searchTerm.toLowerCase();
        models = models.filter((m: any) =>
          m.displayName.toLowerCase().includes(term) ||
          m.subName.toLowerCase().includes(term) ||
          m.modelHost.toLowerCase().includes(term) ||
          m.cloudProvider.toLowerCase().includes(term) ||
          m.modelTier.toLowerCase().includes(term) ||
          m.creator.toLowerCase().includes(term) ||
          m.serverLocation.toLowerCase().includes(term)
        );
      }

      if (locationFilter && locationFilter.value) {
        const loc = locationFilter.value;
        models = models.filter((m: any) => m.serverLocation === loc);
      }

      if (cloudFilter && cloudFilter.value) {
        const cloud = cloudFilter.value;
        models = models.filter((m: any) => m.cloudProvider === cloud);
      }

      if (priceFilter && priceFilter.value) {
        const val = priceFilter.value;
        if (val === '0-2') {
          models = models.filter((m: any) => m.inputPrice >= 0 && m.inputPrice < 2);
        } else if (val === '2-5') {
          models = models.filter((m: any) => m.inputPrice >= 2 && m.inputPrice < 5);
        } else if (val === '5+') {
          models = models.filter((m: any) => m.inputPrice >= 5);
        }
      }

      if (sortKey) {
        models.sort((a: any, b: any) => {
          let va = a[sortKey];
          let vb = b[sortKey];
          if (typeof va === 'number' && typeof vb === 'number') {
            return sortAsc ? va - vb : vb - va;
          }
          va = String(va).toLowerCase();
          vb = String(vb).toLowerCase();
          if (va < vb) return sortAsc ? -1 : 1;
          if (va > vb) return sortAsc ? 1 : -1;
          return 0;
        });
      }

      return models;
    }

    function formatNumber(n: number): string {
      return n != null ? n.toLocaleString('en-US') : '-';
    }

    function formatPrice(n: number): string {
      return n != null ? n.toFixed(2) : '-';
    }

    function render() {
      if (!tbody) return;
      const models = getModels();
      tbody.innerHTML = '';

      for (const m of models) {
        const tr = document.createElement('tr');
        if (m.isSubRow) tr.classList.add('sub-row');

        const hostClass = m.modelHost === 'T-Cloud' ? 'tag-tcloud' : 'tag-cloud';
        const tierClass = m.modelTier === 'Premium' ? 'tag-premium' : 'tag-tier';
        const hostTooltip = hostTooltips[m.modelHost] || '';
        const tierTooltip = tierTooltips[m.modelTier] || '';
        const creatorIcon = brandIcons[m.creator] || '';
        tr.innerHTML = `
          <td>${hostTooltip ? `<span class="ui-tooltip" style="--ui-tooltip-max-width: 26rem;"><span class="ui-tooltip__trigger"><span class="plans-tag ${hostClass}">${m.modelHost}</span></span><span class="ui-tooltip__content" role="tooltip">${hostTooltip}</span></span>` : `<span class="plans-tag ${hostClass}">${m.modelHost}</span>`}</td>
          <td>${m.cloudProvider}</td>
          <td>${tierTooltip ? `<span class="ui-tooltip" style="--ui-tooltip-max-width: 24rem;"><span class="ui-tooltip__trigger"><span class="plans-tag ${tierClass}">${m.modelTier}</span></span><span class="ui-tooltip__content" role="tooltip">${tierTooltip}</span></span>` : `<span class="plans-tag ${tierClass}">${m.modelTier}</span>`}</td>
          <td>
            <span class="creator-brand ${creatorIcon ? 'creator-brand--icon' : 'creator-brand--text'}" title="${m.creator}" aria-label="${m.creator}">
              ${creatorIcon ? `<img class="creator-brand__icon" src="${creatorIcon}" alt="${m.creator}" />` : `<span class="creator-brand__label">${m.creator}</span>`}
            </span>
          </td>
          <td>
            <strong>${m.displayName}</strong>
            ${m.subName && m.subName !== m.displayName ? `<br><small>${m.subName}</small>` : ''}
          </td>
          <td><strong>&euro; ${formatPrice(m.inputPrice)}</strong></td>
          <td><strong>&euro; ${formatPrice(m.outputPrice)}</strong></td>
          <td>${m.locationCode ? `<span class="fi fi-${m.locationCode}"></span> ` : ''}${m.serverLocation}</td>
          <td>${formatNumber(m.rpm)}</td>
          <td>${formatNumber(m.tpm)}</td>
          <td>${m.contextWindow != null ? formatNumber(m.contextWindow) : '-'}</td>
          <td>
            <span class="model-links">
              ${m.termsOfUseUrl ? `<a href="${m.termsOfUseUrl}" class="model-links__item" target="_blank" rel="noreferrer noopener">${translations.linkTermsOfUse || 'Terms of Use'}<svg class="model-links__icon" viewBox="0 0 24 24" fill="none" aria-hidden="true"><path d="M14 3H21V10"/><path d="M21 3L10 14"/><path d="M11 5H6C4.89543 5 4 5.89543 4 7V18C4 19.1046 4.89543 20 6 20H17C18.1046 20 19 19.1046 19 18V13"/></svg></a>` : ''}
              ${m.dataProtectionUrl ? `<a href="${m.dataProtectionUrl}" class="model-links__item" target="_blank" rel="noreferrer noopener">${translations.linkDataProtection || 'Data Protection'}<svg class="model-links__icon" viewBox="0 0 24 24" fill="none" aria-hidden="true"><path d="M14 3H21V10"/><path d="M21 3L10 14"/><path d="M11 5H6C4.89543 5 4 5.89543 4 7V18C4 19.1046 4.89543 20 6 20H17C18.1046 20 19 19.1046 19 18V13"/></svg></a>` : ''}
              ${!m.termsOfUseUrl && !m.dataProtectionUrl ? '<span class="model-links__empty">-</span>' : ''}
            </span>
          </td>
        `;
        tbody.appendChild(tr);
      }

      if (models.length === 0) {
        const tr = document.createElement('tr');
        tr.innerHTML = `<td colspan="12" style="text-align:center;padding:1rem;">${translations.noModels || 'No models found.'}</td>`;
        tbody.appendChild(tr);
      }

      // Update sort icons
      if (table) {
        table.querySelectorAll('th[data-sort]').forEach(th => {
          const icon = th.querySelector('.sort-icon') as HTMLElement;
          if (!icon) return;
          const key = (th as HTMLElement).dataset.sort;
          if (key === sortKey) {
            icon.textContent = sortAsc ? '\u25B4' : '\u25BE';
            icon.classList.add('active');
          } else {
            icon.textContent = '\u25B4\u25BE';
            icon.classList.remove('active');
          }
        });
      }
    }

    // Event: plan selector
    if (selector && !locked) {
      selector.addEventListener('change', () => {
        currentIndex = parseInt(selector.value, 10);
        populateFilterDropdowns();
        render();
      });
    }

    // Event: search
    if (searchInput) {
      searchInput.addEventListener('input', () => {
        searchTerm = searchInput.value;
        render();
      });
    }

    // Event: location filter
    if (locationFilter) {
      locationFilter.addEventListener('change', () => render());
    }

    // Event: cloud filter
    if (cloudFilter) {
      cloudFilter.addEventListener('change', () => render());
    }

    // Event: price filter
    if (priceFilter) {
      priceFilter.addEventListener('change', () => render());
    }

    // Event: sortable headers
    if (table) {
      table.querySelectorAll('th[data-sort]').forEach(th => {
        th.addEventListener('click', () => {
          const key = (th as HTMLElement).dataset.sort || '';
          if (sortKey === key) {
            sortAsc = !sortAsc;
          } else {
            sortKey = key;
            sortAsc = true;
          }
          render();
        });
      });
    }

    populateFilterDropdowns();
    render();
  }

  // Run on initial load and on Astro page transitions
  document.addEventListener('astro:page-load', initPlansPage);
  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', initPlansPage);
  } else {
    initPlansPage();
  }
</script>

